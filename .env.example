# --- Veri sağlayıcı (zorunlu, prod) ---
# ScrapeCreators API anahtarı: https://scrapecreators.com
SCRAPECREATORS_API_KEY=

# --- Claude API (kişilik testi için zorunlu, prod) ---
ANTHROPIC_API_KEY=

# --- Cache (opsiyonel ama prod'da şiddetle önerilir) ---
# Supabase projesi: https://supabase.com — yoksa in-memory cache kullanılır
# (serverless ortamda in-memory cache istekler arasında KALICI DEĞİLDİR)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- AdSense (opsiyonel) ---
# ca-pub-XXXXXXXXXXXXXXXX formatında. Boşsa reklam kodu hiç yüklenmez.
NEXT_PUBLIC_ADSENSE_CLIENT=
# Sonuç sayfası / landing reklam slot id'leri (AdSense panelinden)
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_LANDING=

# --- Site ---
# Prod'da https://threadstalker.xyz — kart imzası ve OG görselleri bu domainden türetilir
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Geliştirme ---
# true iken dış API'lere gitmeden sahte veriyle çalışır (UI geliştirme için)
MOCK_DATA=false
